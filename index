<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cash Flow Analyzer · Pulse Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════
   DESIGN TOKENS
   Color rule:
     --navy  → all data values, structure
     --blue  → brand accent, bars, active states
     --gray  → labels, secondary, muted info
     --red   → action-required ONLY (anomalies, pending)
     --white / --bg → surfaces
   ═══════════════════════════════════════════════ */
:root {
  --navy:    #051C2C;
  --blue:    #2251FF;
  --bg:      #F5F5F2;
  --gray:    #888888;
  --gray-lt: #BBBBBB;
  --white:   #FFFFFF;
  --body:    #1A1A2E;
  --red:     #D32F2F;
  --border:  #E8E8E5;
  --brd-mid: #D5D5D2;
  --inputbg: #FFFDE7;
  --surface2:#F9F9F7;
  --teal:    #134E64;

  --font-h: 'EB Garamond', Georgia, serif;
  --font-b: 'Noto Sans SC', 'PingFang SC', sans-serif;

  --sh-sm: 0 1px 2px rgba(5,28,44,.04), 0 2px 8px rgba(5,28,44,.05);
  --sh-md: 0 2px 4px rgba(5,28,44,.04), 0 8px 24px rgba(5,28,44,.08),
           0 1px 0 rgba(255,255,255,.60) inset;
  --sh-nav: 0 1px 0 rgba(255,255,255,.06), 0 4px 20px rgba(5,28,44,.35);

  --ease:   cubic-bezier(.25,.46,.45,.94);
  --spring: cubic-bezier(.34,1.56,.64,1.0);
  --decel:  cubic-bezier(0,.0,.2,1);
}

*,*::before,*::after { box-sizing:border-box; margin:0; padding:0; }

body {
  background: var(--bg);
  color: var(--body);
  font-family: var(--font-b);
  font-size: 13px;
  line-height: 1.6;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ── NAV ───────────────────────────────────────── */
.nav {
  position: sticky; top: 0; z-index: 200;
  height: 56px;
  background: rgba(5,28,44,.92);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  box-shadow: var(--sh-nav);
  display: flex; align-items: center;
}
.nav-inner {
  max-width: 1440px; margin: 0 auto;
  padding: 0 32px;
  display: flex; align-items: center; width: 100%;
}
.nav-brand {
  font-family: var(--font-h);
  font-size: 16px; font-weight: 700;
  color: var(--white); margin-right: 40px;
  white-space: nowrap; cursor: default;
  letter-spacing: -.02em;
}
.nav-brand em { color: var(--blue); font-style: normal; }
.nav-tabs { display: flex; }
.nav-tab {
  height: 56px; padding: 0 20px;
  display: flex; align-items: center; gap: 7px;
  cursor: pointer;
  font-family: var(--font-h);
  font-size: 13px; font-weight: 600;
  color: rgba(255,255,255,.50);
  border-bottom: 3px solid transparent;
  transition: color 140ms var(--ease), border-color 140ms var(--ease);
  user-select: none; white-space: nowrap;
}
.nav-tab:hover { color: rgba(255,255,255,.82); }
.nav-tab.active { color: var(--white); border-bottom-color: var(--blue); }
.nav-right {
  margin-left: auto;
  display: flex; align-items: center; gap: 12px;
}
.nav-date { font-size: 11px; color: rgba(255,255,255,.35); font-family: monospace; }
.nav-alert-pill {
  background: var(--red);
  color: var(--white);
  font-size: 10px; font-weight: 700;
  padding: 2px 9px; border-radius: 100px;
}

/* ── LAYOUT ────────────────────────────────────── */
.wrap {
  max-width: 1440px; margin: 0 auto;
  padding: 48px 32px 80px;
}
.view { display: none; }
.view.active { display: block; animation: fadeUp 420ms var(--decel) both; }

/* ── PAGE HEADER ───────────────────────────────── */
.pg-hdr { margin-bottom: 32px; }
.pg-title {
  font-family: var(--font-h);
  font-size: 28px; font-weight: 700;
  color: var(--navy); letter-spacing: -.03em; line-height: 1.15;
}
.pg-sub { font-size: 11px; color: var(--gray); margin-top: 4px; }

/* ── SECTION LABELS ────────────────────────────── */
.sec-lbl {
  font-family: var(--font-h);
  font-size: 11px; font-weight: 700;
  color: var(--navy); text-transform: uppercase; letter-spacing: .10em;
}
.sec-rule {
  flex: 1; height: 1px; background: var(--brd-mid); margin-left: 12px;
}
.sec-hdr {
  display: flex; align-items: center;
  margin-bottom: 16px; padding-bottom: 12px;
  border-bottom: 2px solid var(--blue);
}

/* ── DUAL PANEL ────────────────────────────────── */
.dual {
  display: grid;
  grid-template-columns: 1fr 1px 1fr;
  gap: 36px; margin-bottom: 44px; align-items: start;
}
.panel-div { width: 1px; background: var(--brd-mid); align-self: stretch; margin-top: 44px; }

/* ── KPI CARDS ─────────────────────────────────── */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
.kpi-card {
  background: var(--white);
  border-radius: 14px;
  padding: 16px 20px 20px;
  box-shadow: var(--sh-md);
  border-left: 3px solid var(--blue);
  transition: transform 260ms var(--spring), box-shadow 260ms var(--ease);
  animation: fadeUp 420ms var(--decel) both;
}
/* Action-required card: only pending/anomaly */
.kpi-card.action { border-left-color: var(--red); }

.kpi-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 8px rgba(5,28,44,.06), 0 16px 48px rgba(5,28,44,.12);
}
.kpi-card.span2 { grid-column: span 2; }

.kpi-lbl {
  font-size: 10px; font-weight: 500;
  color: var(--gray); text-transform: uppercase; letter-spacing: .08em;
  margin-bottom: 8px;
}
/* All KPI values: uniform navy */
.kpi-val {
  font-family: var(--font-h);
  font-size: 30px; font-weight: 700;
  color: var(--navy);
  letter-spacing: -.03em; line-height: 1.05;
  font-variant-numeric: tabular-nums;
}
.kpi-val.sm  { font-size: 22px; }
.kpi-val.action { color: var(--red); }   /* only for action-required values */
.kpi-sub {
  font-size: 10px; color: var(--gray); margin-top: 4px; line-height: 1.4;
}
.kpi-fml {
  font-family: 'Courier New', monospace;
  font-size: 9px; color: var(--teal);
  background: rgba(19,78,100,.06);
  padding: 1px 5px; border-radius: 2px;
  margin-top: 4px; display: inline-block;
}

/* ── PROGRESS BARS ─────────────────────────────── */
.bar-wrap { margin-top: 12px; }
.bar-meta {
  display: flex; justify-content: space-between;
  font-size: 9px; color: var(--gray); margin-bottom: 4px;
}
.bar-track {
  height: 5px; background: var(--border);
  border-radius: 100px; overflow: hidden;
}
.bar-fill {
  height: 100%; border-radius: 100px;
  background: var(--blue);              /* brand blue — normal state */
  width: 0%;
  transition: width 900ms var(--spring);
}
.bar-fill.over { background: var(--red); } /* overbudget → action required */

/* ── STATUS BADGES ─────────────────────────────── */
.badge {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 2px 9px; border-radius: 100px;
  font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .04em;
  white-space: nowrap;
}
/* Only two semantic badge states */
.badge-action { background: rgba(211,47,47,.10); color: var(--red); }
.badge-neutral { background: rgba(5,28,44,.07);  color: var(--gray); }

/* ── TABLES ────────────────────────────────────── */
.tbl-wrap {
  background: var(--white);
  border-radius: 10px;
  box-shadow: var(--sh-md);
  overflow: hidden;
  margin-bottom: 20px;
}
.tbl-hdr {
  background: var(--navy);
  padding: 11px 20px;
  display: flex; align-items: center; justify-content: space-between;
}
.tbl-hdr-title {
  font-family: var(--font-h);
  font-size: 11px; font-weight: 700;
  color: var(--white); text-transform: uppercase; letter-spacing: .08em;
}
.tbl-chips { display: flex; gap: 8px; }
.chip {
  background: rgba(255,255,255,.12);
  color: rgba(255,255,255,.70);
  font-size: 10px; padding: 2px 8px; border-radius: 100px;
}
.chip.alert { background: rgba(211,47,47,.30); color: var(--white); }

.tbl-scroll { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; }
thead th {
  background: var(--navy);
  color: rgba(255,255,255,.65);
  font-family: var(--font-h);
  font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .07em;
  padding: 8px 12px; text-align: left; white-space: nowrap;
  border-bottom: 1px solid rgba(255,255,255,.07);
}
thead th.r { text-align: right; }
thead th.c { text-align: center; }
tbody tr { border-bottom: 1px solid var(--border); }
tbody tr:nth-child(even) { background: var(--bg); }
tbody tr:nth-child(odd)  { background: var(--white); }
tbody tr:last-child { border-bottom: none; }
tbody tr:hover { background: rgba(34,81,255,.04); }
tbody tr.pend-row { background: rgba(211,47,47,.04) !important; }
tbody tr.pend-row:hover { background: rgba(211,47,47,.07) !important; }
tbody tr.curr-row { background: rgba(34,81,255,.06) !important; }
tbody tr.curr-row td { font-weight: 600; }
td {
  padding: 9px 12px;
  font-size: 12px; color: var(--navy);    /* uniform navy for all data */
  white-space: nowrap;
}
td.r  { text-align: right; font-variant-numeric: tabular-nums; }
td.c  { text-align: center; }
td.muted  { color: var(--gray); }
td.mono   { font-family: 'Courier New', monospace; font-size: 11px; color: var(--gray); }
td.fml    { font-family: 'Courier New', monospace; font-size: 10px; color: var(--teal); background: rgba(19,78,100,.04); }
td.inp    { background: var(--inputbg) !important; }
td.alert  { color: var(--red) !important; font-weight: 700; }  /* anomalies only */
td.dim    { color: var(--border); }

/* ── PENDING BANNER ────────────────────────────── */
.pend-banner {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 12px 16px;
  background: rgba(211,47,47,.05);
  border-left: 4px solid var(--red);
  border-radius: 8px;
  margin-bottom: 16px;
}
.pend-title {
  font-family: var(--font-h);
  font-size: 14px; font-weight: 700; color: var(--navy);
}
.pend-count {
  background: var(--red); color: var(--white);
  font-size: 10px; font-weight: 700;
  padding: 1px 8px; border-radius: 100px; margin-left: 8px;
}
.pend-desc { font-size: 11px; color: var(--gray); margin-top: 2px; }

/* ── FORMULA CARD ──────────────────────────────── */
.fml-card {
  background: var(--white); border-radius: 10px;
  box-shadow: var(--sh-sm); padding: 20px;
  border-top: 3px solid var(--teal); margin-top: 20px;
}
.fml-card-title {
  font-family: var(--font-h);
  font-size: 11px; font-weight: 700;
  color: var(--teal); text-transform: uppercase; letter-spacing: .08em;
  margin-bottom: 16px;
}
.fml-row {
  display: grid; grid-template-columns: 180px 1fr;
  gap: 12px; align-items: start;
  padding: 8px 0; border-bottom: 1px solid var(--border);
}
.fml-row:last-child { border-bottom: none; }
.fml-metric { font-size: 12px; font-weight: 600; color: var(--navy); }
.fml-expr {
  font-family: 'Courier New', monospace;
  font-size: 10px; color: var(--teal);
  background: rgba(19,78,100,.05);
  padding: 3px 8px; border-radius: 3px; line-height: 1.9;
}
.fml-result { font-weight: 700; color: var(--navy); margin-left: 8px; }

/* ── CONFIG ────────────────────────────────────── */
.cfg-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
.cfg-sect { background: var(--white); border-radius: 10px; box-shadow: var(--sh-sm); overflow: hidden; }
.cfg-hdr {
  background: var(--navy); padding: 8px 16px;
  display: flex; align-items: baseline; gap: 8px;
}
.cfg-hdr-title {
  font-family: var(--font-h); font-size: 10px; font-weight: 700;
  color: var(--white); text-transform: uppercase; letter-spacing: .08em;
}
.cfg-hdr-ref { font-size: 9px; color: rgba(255,255,255,.35); font-family: monospace; }

/* ── SPARKLINE ─────────────────────────────────── */
.spark-card {
  background: var(--white); border-radius: 10px;
  box-shadow: var(--sh-sm); padding: 16px 20px;
  margin-bottom: 24px;
}
.spark-lbl {
  font-size: 11px; color: var(--gray); text-transform: uppercase;
  letter-spacing: .07em; font-weight: 500; margin-bottom: 10px;
}
.spark-svg { width: 100%; height: 70px; display: block; }

/* ── MISC ──────────────────────────────────────── */
.note {
  font-size: 10px; color: var(--gray);
  background: var(--white); border-radius: 6px;
  padding: 8px 12px; margin-top: 8px;
  box-shadow: var(--sh-sm);
}
.inline-fml {
  font-family: 'Courier New', monospace; font-size: 9px;
  color: var(--teal); background: rgba(19,78,100,.06);
  padding: 1px 5px; border-radius: 2px;
}
.live-dot {
  display: inline-block; width: 6px; height: 6px; border-radius: 50%;
  background: var(--blue); margin-right: 4px;
  animation: pulse 2.5s ease-in-out infinite;
}

@keyframes fadeUp {
  from { opacity:0; transform:translateY(10px); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes pulse {
  0%,100% { opacity:1; } 50% { opacity:.35; }
}
.kpi-card:nth-child(1){animation-delay: 30ms;}
.kpi-card:nth-child(2){animation-delay: 80ms;}
.kpi-card:nth-child(3){animation-delay:130ms;}
.kpi-card:nth-child(4){animation-delay:180ms;}
.kpi-card:nth-child(5){animation-delay:230ms;}
.kpi-card:nth-child(6){animation-delay:280ms;}

@media(max-width:900px){
  .dual{grid-template-columns:1fr;gap:24px;}
  .panel-div{display:none;}
  .kpi-grid{grid-template-columns:1fr 1fr;}
  .cfg-grid{grid-template-columns:1fr;}
  .fml-row{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="nav-inner">
    <div class="nav-brand">Cash Flow <em>Analyzer</em></div>
    <div class="nav-tabs">
      <div class="nav-tab" id="tab-config"    onclick="switchTab('config')">⚙ Config Setup</div>
      <div class="nav-tab" id="tab-ledger"    onclick="switchTab('ledger')">📋 Ledger</div>
      <div class="nav-tab" id="tab-engine"    onclick="switchTab('engine')">∑ Engine</div>
      <div class="nav-tab active" id="tab-dashboard" onclick="switchTab('dashboard')">◉ Dashboard</div>
    </div>
    <div class="nav-right">
      <div class="nav-date">2026-06-06</div>
      <div class="nav-alert-pill" id="nav-pend">1 Pending</div>
    </div>
  </div>
</nav>

<div class="wrap">

<!-- ════ DASHBOARD ══════════════════════════════ -->
<div class="view active" id="view-dashboard">
  <div class="pg-hdr">
    <div class="pg-title">◉ Pulse Dashboard</div>
    <div class="pg-sub">
      <span class="live-dot"></span>
      Weekly Partner Check-In · Formula-driven from Data_Transactions
    </div>
  </div>

  <div class="dual">
    <!-- LEFT — Business Health -->
    <div>
      <div class="sec-hdr">
        <div class="sec-lbl">Business Health</div>
        <div class="sec-rule"></div>
      </div>
      <div class="kpi-grid">

        <!-- Runway: featured card -->
        <div class="kpi-card span2">
          <div class="kpi-lbl">Business Runway</div>
          <div style="display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;">
            <div class="kpi-val" id="d-runway">9.3</div>
            <div style="font-family:var(--font-h);font-size:17px;color:var(--gray);">months remaining</div>
          </div>
          <div class="bar-wrap">
            <div class="bar-meta">
              <span>0</span>
              <span>1.5 critical</span>
              <span>3.0 safe</span>
              <span>12 mo</span>
            </div>
            <div class="bar-track"><div class="bar-fill" id="d-runway-fill"></div></div>
          </div>
          <div class="kpi-fml">=Cumul_Biz_Cash / Monthly_Burn_Rate = $24,550 / $2,650</div>
        </div>

        <div class="kpi-card">
          <div class="kpi-lbl">Weekly Biz Net CF</div>
          <div class="kpi-val" id="d-biz-net">+$1,050</div>
          <div class="kpi-fml">=Income − OpEx − Draw</div>
        </div>

        <div class="kpi-card">
          <div class="kpi-lbl">Business Cash Position</div>
          <div class="kpi-val" id="d-cash">$24,550</div>
          <div class="kpi-fml">=Opening + Σ Biz Net CF</div>
        </div>

        <div class="kpi-card">
          <div class="kpi-lbl">Monthly Burn Rate</div>
          <div class="kpi-val sm" id="d-burn">$2,650</div>
          <div class="kpi-sub">/month — 91-day rolling avg</div>
          <div class="kpi-fml">=SUMIFS(Outflows,last 91d)/3</div>
        </div>

        <div class="kpi-card">
          <div class="kpi-lbl">Anchor Date</div>
          <div class="kpi-val sm" style="font-size:19px;">2026-06-06</div>
          <div class="kpi-sub">Saturday · Week 23</div>
          <div class="kpi-fml">=TODAY()</div>
        </div>

      </div>
    </div>

    <div class="panel-div"></div>

    <!-- RIGHT — Personal Budget Pacing -->
    <div>
      <div class="sec-hdr">
        <div class="sec-lbl">Personal Budget Pacing</div>
        <div class="sec-rule"></div>
      </div>
      <div class="kpi-grid">

        <!-- Budget pacing: featured card -->
        <div class="kpi-card span2">
          <div class="kpi-lbl">Weekly Discretionary Spending</div>
          <div style="display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;">
            <div class="kpi-val" id="d-spent">$130</div>
            <div style="font-family:var(--font-h);font-size:17px;color:var(--gray);">of $300 weekly limit</div>
          </div>
          <div class="bar-wrap">
            <div class="bar-meta">
              <span>$0</span>
              <span id="d-bar-mid">$130 spent · 43% used</span>
              <span>$300 cap</span>
            </div>
            <div class="bar-track"><div class="bar-fill" id="d-budget-fill"></div></div>
          </div>
          <div class="kpi-fml">=SUMIFS(Amt, Entity=Personal, Type=Outflow, Cat=Discretionary, Week=Current)</div>
        </div>

        <div class="kpi-card">
          <div class="kpi-lbl">Budget Variance</div>
          <div class="kpi-val" id="d-variance">+$170</div>
          <div class="kpi-sub">remaining this week</div>
        </div>

        <div class="kpi-card">
          <div class="kpi-lbl">Weekly Pulse Result</div>
          <div class="kpi-val sm" id="d-pulse">GREEN LIGHT</div>
          <div class="kpi-sub">Runway SAFE · Budget &lt; 85%</div>
        </div>

        <div class="kpi-card">
          <div class="kpi-lbl">Personal Net Cash Flow</div>
          <div class="kpi-val" id="d-pers-net">+$1,370</div>
          <div class="kpi-fml">=Income − Survival − Discretion</div>
        </div>

        <!-- Pending: action-required → red accent -->
        <div class="kpi-card action">
          <div class="kpi-lbl">Total Pending Alerts</div>
          <div class="kpi-val action" id="d-pending">1</div>
          <div class="kpi-sub">item requires owner verification</div>
          <div class="kpi-fml">=COUNTIF(Status,"Pending")</div>
        </div>

      </div>
    </div>
  </div>

  <!-- 3-WEEK TREND -->
  <div class="tbl-wrap">
    <div class="tbl-hdr">
      <div class="tbl-hdr-title">3-Week Trend Snapshot</div>
      <div class="tbl-chips"><div class="chip">Calc_Engine rows 10–12</div></div>
    </div>
    <div class="tbl-scroll">
      <table>
        <thead><tr>
          <th>Period</th>
          <th class="r">Biz Income</th><th class="r">Biz OpEx</th><th class="r">Draw</th><th class="r">Biz Net CF</th>
          <th class="r">Pers Income</th><th class="r">Survival</th><th class="r">Discretion</th><th class="r">Pers Net CF</th>
          <th class="r">Cum. Cash</th><th class="r">Runway</th>
        </tr></thead>
        <tbody id="trend-tbody"></tbody>
      </table>
    </div>
  </div>

  <!-- PENDING BANNER + TABLE -->
  <div class="pend-banner">
    <div style="font-size:17px;margin-top:1px;">⚑</div>
    <div>
      <div class="pend-title">Pending Items to Reconcile<span class="pend-count" id="pend-count">1</span></div>
      <div class="pend-desc">
        Target: Count = 0 at end of weekly check-in.
        Populated via <span class="inline-fml">=FILTER(Ledger!B:L, Status="Pending")</span>
      </div>
    </div>
  </div>
  <div class="tbl-wrap">
    <div class="tbl-hdr">
      <div class="tbl-hdr-title">⚑ Pending Transactions — Action Required</div>
      <div class="tbl-chips"><div class="chip alert">1 item</div></div>
    </div>
    <div class="tbl-scroll">
      <table>
        <thead><tr>
          <th>Tx ID</th><th>Date</th><th>Entity</th><th>Type</th>
          <th>Category</th><th>Sub-Category</th>
          <th class="r">Amount</th><th>Description</th>
          <th>Status</th><th class="c">Flag</th>
