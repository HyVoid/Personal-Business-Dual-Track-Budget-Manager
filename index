  {id:'TX-2026-0007',date:'2026-06-04',ent:'Personal',typ:'Outflow',cat:'Discretionary Expenses',     sub:'Dining Out',         amt:85,   desc:'Dinner — The Capital Grille',            st:'Cleared'},
  {id:'TX-2026-0008',date:'2026-05-28',ent:'Business',typ:'Inflow', cat:'Business Income',            sub:'Service Fees',       amt:2500, desc:'Retainer — XYZ Consulting Ltd',         st:'Cleared'},
  {id:'TX-2026-0009',date:'2026-05-29',ent:'Business',typ:'Outflow',cat:'Business Operating Expense', sub:'Payroll',            amt:4000, desc:'Contractor payment — Dev team',          st:'Cleared'},
  {id:'TX-2026-0010',date:'2026-05-26',ent:'Personal',typ:'Outflow',cat:'Survival Expenses',          sub:'Groceries',          amt:200,  desc:'Weekly groceries — Whole Foods',         st:'Cleared'},
  {id:'TX-2026-0011',date:'2026-05-27',ent:'Personal',typ:'Outflow',cat:'Discretionary Expenses',     sub:'Shopping',           amt:150,  desc:'Amazon order — home office supplies',    st:'Cleared'},
  {id:'TX-2026-0012',date:'2026-06-06',ent:'Personal',typ:'Outflow',cat:'Discretionary Expenses',     sub:'Entertainment',      amt:45,   desc:'Netflix annual subscription',            st:'Pending'},
];

const TAXONOMY = [
  {g:'Revenue',c:'Business Income',           s:'Acquisition'},
  {g:'Revenue',c:'Business Income',           s:'Service Fees'},
  {g:'Revenue',c:'Business Income',           s:'Retainer'},
  {g:'Expense',c:'Business Operating Expense',s:'SaaS Subscriptions'},
  {g:'Expense',c:'Business Operating Expense',s:'Payroll'},
  {g:'Expense',c:'Business Operating Expense',s:'Rent (Office)'},
  {g:'Expense',c:'Business Operating Expense',s:'Marketing'},
  {g:'Expense',c:'Business Operating Expense',s:'Travel & Entertainment'},
  {g:'Expense',c:"Owner's Draw",              s:"Owner's Draw"},
  {g:'Revenue',c:'Personal Income',           s:'Active Salary'},
  {g:'Revenue',c:'Personal Income',           s:'Other Personal Income'},
  {g:'Expense',c:'Survival Expenses',         s:'Rent (Home)'},
  {g:'Expense',c:'Survival Expenses',         s:'Utilities'},
  {g:'Expense',c:'Survival Expenses',         s:'Groceries'},
  {g:'Expense',c:'Discretionary Expenses',    s:'Dining Out'},
  {g:'Expense',c:'Discretionary Expenses',    s:'Shopping'},
  {g:'Expense',c:'Discretionary Expenses',    s:'Luxury'},
  {g:'Expense',c:'Discretionary Expenses',    s:'Entertainment'},
  {g:'Savings',c:'Savings',                   s:'Emergency Fund'},
  {g:'Savings',c:'Savings',                   s:'Investment'},
];

/* ─── ENGINE ────────────────────────────────── */
const CURR_WEEK_START = new Date('2026-06-01T00:00:00');

function sumifs(f) {
  return TX.filter(t => {
    if (f.ent && t.ent !== f.ent) return false;
    if (f.typ && t.typ !== f.typ) return false;
    if (f.cat && t.cat !== f.cat) return false;
    if (f.sub && t.sub !== f.sub) return false;
    const d = new Date(t.date + 'T00:00:00');
    if (f.dGte && d < f.dGte) return false;
    if (f.dLte && d > f.dLte) return false;
    return true;
  }).reduce((s, t) => s + t.amt, 0);
}

function computeWeeks() {
  const weeks = [];
  for (let i = 11; i >= 0; i--) {
    const ws = new Date(CURR_WEEK_START);
    ws.setDate(ws.getDate() - i * 7);
    const we = new Date(ws); we.setDate(we.getDate() + 6);

    const bizIn   = sumifs({ent:'Business',typ:'Inflow', dGte:ws,dLte:we});
    const bizOpEx = sumifs({ent:'Business',typ:'Outflow',cat:'Business Operating Expense',dGte:ws,dLte:we});
    const bizDraw = sumifs({ent:'Business',typ:'Outflow',cat:"Owner's Draw",dGte:ws,dLte:we});
    const bizNet  = bizIn - bizOpEx - bizDraw;
    const persIn  = sumifs({ent:'Personal',typ:'Inflow', dGte:ws,dLte:we});
    const persSurv= sumifs({ent:'Personal',typ:'Outflow',cat:'Survival Expenses',dGte:ws,dLte:we});
    const persDisc= sumifs({ent:'Personal',typ:'Outflow',cat:'Discretionary Expenses',dGte:ws,dLte:we});
    const persNet = persIn - persSurv - persDisc;

    const d91 = new Date(we); d91.setDate(d91.getDate() - 91);
    const burnRate = sumifs({ent:'Business',typ:'Outflow',dGte:d91,dLte:we}) / 3;

    const d3s = new Date(ws); d3s.setDate(d3s.getDate() - 3);
    const d3e = new Date(we); d3e.setDate(d3e.getDate() + 3);
    const salary = sumifs({ent:'Personal',typ:'Inflow',sub:'Active Salary',dGte:d3s,dLte:d3e});
    const drawCheck = bizDraw === 0 ? 'N/A' : (Math.abs(bizDraw - salary) < 0.01 ? '✓ OK' : '⚠ MISMATCH');

    weeks.push({
      num: 12 - i, isCurrent: i === 0,
      ws: fmtDate(ws), we: fmtDate(we),
      bizIn, bizOpEx, bizDraw, bizNet,
      persIn, persSurv, persDisc, persNet,
      burnRate, drawCheck
    });
  }
  let cumul = 25000;
  weeks.forEach(w => { cumul += w.bizNet; w.cumul = cumul; w.runway = w.burnRate > 0 ? cumul / w.burnRate : 0; });
  return weeks;
}

/* ─── FORMATTERS ────────────────────────────── */
function fmtDate(d) { return d.toISOString().split('T')[0]; }
const fmtUSD = n => '$' + Math.abs(n).toLocaleString('en-US', {minimumFractionDigits:2,maximumFractionDigits:2});
/* Single formatter — no color, sign only */
function fmtVal(n) {
  if (n === 0) return '<span style="color:var(--border);">—</span>';
  return (n > 0 ? '+' : '-') + fmtUSD(n);
}
/* Anomaly variant — used only for action-required cells */
function fmtValAlert(n) {
  const base = fmtVal(n);
  return n < 0 ? `<span class="alert">${base}</span>` : base;
}

const WEEKS = computeWeeks();
const CURR  = WEEKS[WEEKS.length - 1];

/* ─── RENDER: LEDGER ────────────────────────── */
function buildLedger() {
  document.getElementById('ledger-tbody').innerHTML = TX.map(t => {
    const isPend = t.st === 'Pending';
    return `<tr${isPend ? ' class="pend-row"' : ''}>
      <td class="mono">${t.id}</td>
      <td>${t.date}</td>
      <td>${t.ent}</td>
      <td class="muted">${t.typ}</td>
      <td style="font-size:11px;">${t.cat}</td>
      <td class="muted" style="font-size:11px;">${t.sub}</td>
      <td class="r">${fmtUSD(t.amt)}</td>
      <td style="font-size:11px;max-width:220px;overflow:hidden;text-overflow:ellipsis;">${t.desc}</td>
      <td><span class="badge ${isPend ? 'badge-action' : 'badge-neutral'}">${isPend ? '⏳ Pending' : 'Cleared'}</span></td>
      <td class="c${isPend ? ' alert' : ' muted'}">${isPend ? 'TRUE' : 'FALSE'}</td>
    </tr>`;
  }).join('');
}

/* ─── RENDER: ENGINE TABLE ──────────────────── */
function buildEngine() {
  document.getElementById('engine-tbody').innerHTML = WEEKS.map(w => {
    const isCurr  = w.isCurrent;
    const rc      = isCurr ? ' class="curr-row"' : '';
    const marker  = isCurr ? ' <span style="background:var(--blue);color:#fff;font-size:9px;padding:1px 5px;border-radius:2px;">LIVE</span>' : '';
    /* Runway: only CRITICAL gets red */
    const rwStyle = w.runway > 0 && w.runway < 1.5 ? ' class="alert"' : '';
    /* Draw check: MISMATCH is an anomaly */
    const dcStyle = w.drawCheck === '⚠ MISMATCH' ? ' class="alert"' : ' class="muted"';
    return `<tr${rc}>
      <td class="muted">${w.num}${marker}</td>
      <td class="mono">${w.ws}</td>
      <td class="mono">${w.we}</td>
      <td class="r">${fmtVal(w.bizIn)}</td>
      <td class="r">${fmtVal(w.bizOpEx)}</td>
      <td class="r">${fmtVal(w.bizDraw)}</td>
      <td class="r">${fmtVal(w.bizNet)}</td>
      <td class="r">${fmtVal(w.persIn)}</td>
      <td class="r">${fmtVal(w.persSurv)}</td>
      <td class="r">${fmtVal(w.persDisc)}</td>
      <td class="r">${fmtVal(w.persNet)}</td>
      <td class="r">${fmtUSD(w.cumul)}</td>
      <td class="r muted">${w.burnRate > 0 ? fmtUSD(w.burnRate)+'/mo' : '<span style="color:var(--border);">—</span>'}</td>
      <td class="r"${rwStyle}>${w.runway > 0 ? w.runway.toFixed(1)+' mo' : '<span style="color:var(--border);">—</span>'}</td>
      <td class="c"${dcStyle}>${w.drawCheck}</td>
    </tr>`;
  }).join('');
}

/* ─── RENDER: TREND ─────────────────────────── */
