/* ─── RENDER: SPARKLINE ─────────────────────── */
function buildSparkline() {
  const svg = document.getElementById('spark-svg');
  const W = 900, H = 70, PX = 20, PY = 12;
  const vals = WEEKS.map(w => w.cumul);
  const minV = Math.min(...vals) - 300;
  const maxV = Math.max(...vals) + 300;
  const sx = i => PX + (i / (WEEKS.length - 1)) * (W - PX * 2);
  const sy = v => PY + ((maxV - v) / (maxV - minV)) * (H - PY * 2);
  const pts = WEEKS.map((w, i) => `${sx(i)},${sy(w.cumul)}`).join(' ');
  const area = `M ${sx(0)},${sy(WEEKS[0].cumul)} `
    + WEEKS.slice(1).map((w,i) => `L ${sx(i+1)},${sy(w.cumul)}`).join(' ')
    + ` L ${sx(11)},${H} L ${sx(0)},${H} Z`;
  const refY = sy(25000);
  svg.innerHTML = `
    <defs>
      <linearGradient id="ag" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"   stop-color="#2251FF" stop-opacity=".12"/>
        <stop offset="100%" stop-color="#2251FF" stop-opacity="0"/>
      </linearGradient>
    </defs>
    <line x1="${PX}" y1="${refY}" x2="${W-PX}" y2="${refY}"
          stroke="#BBBBBB" stroke-width="1" stroke-dasharray="4 3"/>
    <path d="${area}" fill="url(#ag)"/>
    <polyline points="${pts}" fill="none" stroke="#2251FF" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round"/>
    ${WEEKS.map((w,i) => {
      const x = sx(i), y = sy(w.cumul), c = w.isCurrent;
      return `<circle cx="${x}" cy="${y}" r="${c?4.5:2.5}"
        fill="${c?'#2251FF':'#fff'}" stroke="#2251FF" stroke-width="${c?0:1.5}"/>`;
    }).join('')}
    <text x="${sx(11)-4}" y="${sy(CURR.cumul)-8}"
          text-anchor="end" font-size="9" fill="#051C2C" font-weight="700"
          font-family="EB Garamond,serif">$${Math.round(CURR.cumul).toLocaleString()}</text>
    ${[0,5,11].map(i =>
      `<text x="${sx(i)}" y="${H-1}" text-anchor="middle"
             font-size="8" fill="#BBBBBB" font-family="monospace">${WEEKS[i].ws.slice(5)}</text>`
    ).join('')}`;
}

/* ─── ANIMATIONS ────────────────────────────── */
function triggerDash() {
  setTimeout(() => {
    const pct = CURR.persDisc / 300;
    const fill = document.getElementById('d-budget-fill');
    fill.style.width = Math.min(pct * 100, 100) + '%';
    if (pct > 1) fill.classList.add('over');
    else         fill.classList.remove('over');

    const rfill = document.getElementById('d-runway-fill');
    rfill.style.width = Math.min((CURR.runway / 12) * 100, 100) + '%';
  }, 80);
}

/* ─── TAB SWITCH ────────────────────────────── */
function switchTab(name) {
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  document.getElementById('view-' + name).classList.add('active');
  if (name === 'dashboard') triggerDash();
}

/* ─── INIT ──────────────────────────────────── */
buildLedger();
buildEngine();
buildTrend();
buildTaxonomy();
buildSparkline();
triggerDash();
</script>
</body>
